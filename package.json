{
  "name": "festival-companion",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A child-friendly, static web app introducing Hindu festivals before a temple visit.",
  "scripts": {
    "dev": "node scripts/serve.mjs",
    "start": "node scripts/serve.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "node scripts/validate-data.mjs",
    "gen:art": "node scripts/make-art.mjs",
    "gen:narration": "node scripts/gen-narration.mjs",
    "format": "prettier --write \"**/*.{js,mjs,css,json,md,html}\"",
    "format:check": "prettier --check \"**/*.{js,mjs,css,json,md,html}\"",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "eslint": "^9.13.0",
    "globals": "^15.11.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "vitest": "^2.1.4"
  }
}
